# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
lib/
*.tsbuildinfo

# Test / coverage
coverage/
test-results/
playwright-report/
__pycache__/
*.py[cod]

# Turborepo
.turbo/
# `turbo prune --docker` scratch output (also produced inside Dockerfile stages)
out/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env files (never commit secrets). Sanitized example templates are allowed.
.env
.env.*
!.env.example
!.env*.example
# Smoke-test scratch env created by packages/core/scripts/docker-smoke-test.sh.
.env.docker-smoke-test

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Local-only scratch
.tmp/
tmp/
*.local

# Local raw-storage filesystem data (RAW_STORAGE_LOCAL_FS_ROOT defaults).
data/raw-storage/
