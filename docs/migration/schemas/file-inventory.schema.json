{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/atomicstrata/atomicmemory/docs/migration/schemas/file-inventory.schema.json",
  "title": "AtomicMemory Source Snapshot File Inventory",
  "type": "object",
  "required": [
    "id",
    "source_repo",
    "source_ref",
    "source_commit",
    "target_path",
    "target_commit",
    "allowlist",
    "copied_on",
    "copy_tool",
    "files",
    "summary",
    "verification"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "source_repo": {
      "type": "string"
    },
    "source_ref": {
      "type": "string"
    },
    "source_commit": {
      "type": "string"
    },
    "source_subpath": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_path": {
      "type": "string"
    },
    "target_commit": {
      "type": "string"
    },
    "allowlist": {
      "type": "string"
    },
    "copied_on": {
      "type": "string"
    },
    "copy_tool": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_path",
          "target_path",
          "sha256",
          "size_bytes",
          "matched_include"
        ],
        "properties": {
          "source_path": {
            "type": "string"
          },
          "target_path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "matched_include": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object"
    },
    "verification": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
