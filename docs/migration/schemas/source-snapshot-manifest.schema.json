{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/atomicstrata/atomicmemory/docs/migration/schemas/source-snapshot-manifest.schema.json",
  "title": "AtomicMemory Source Snapshot Manifest",
  "type": "object",
  "required": [
    "target_repo",
    "copy_method_default",
    "manifest_recorded_on",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "target_repo": {
      "const": "atomicstrata/atomicmemory"
    },
    "copy_method_default": {
      "const": "clean source snapshot, no git history"
    },
    "manifest_recorded_on": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "id",
        "source_repo",
        "source_ref",
        "source_commit",
        "package_name",
        "package_pre_migration_version",
        "target_path",
        "allowlist",
        "copy_method",
        "initial_monorepo_commit",
        "status",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "source_repo": {
          "type": "string",
          "pattern": "^atomicstrata/[A-Za-z0-9._-]+$"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "source_subpath": {
          "type": "string",
          "minLength": 1
        },
        "package_name": {
          "type": "string",
          "minLength": 1
        },
        "package_pre_migration_version": {
          "type": "string",
          "minLength": 1
        },
        "target_path": {
          "type": "string",
          "pattern": "^(packages|adapters|plugins)/[a-z0-9-]+$"
        },
        "allowlist": {
          "type": "string",
          "pattern": "^docs/migration/allowlists/[a-z0-9-]+\\.json$"
        },
        "copy_method": {
          "const": "clean source snapshot, no git history"
        },
        "initial_monorepo_commit": {
          "type": "string",
          "pattern": "^(TBD|[a-f0-9]{7,40})$"
        },
        "status": {
          "enum": [
            "planned",
            "copied"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
