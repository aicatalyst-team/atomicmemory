# Build outputs
dist/
*.tsbuildinfo

# Dependencies
node_modules/

# Environment files — NEVER commit. They contain real API keys.
# Pattern below ignores every .env.* except sanitized example templates.
.env
.env.*
!.env.example
!.env*.example
.mcp.json

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.log
.cache/

# Local commit/PR composition scratch (workspace convention — never committed)
commit-message.txt
pr-description.md

# Generated files
*.db

# Evaluation/trace artifacts (generated by local runs)
.traces/
.eval-cache/
.eval-cache-chunked/
.eval-cache-locomo/
.eval-chunks/

# Test results
test-results/
coverage/

# Schemathesis run artifacts (generated by tests/schema/run-schemathesis.sh)
schemathesis-report.json
schemathesis-report.xml
schemathesis-cassette.yaml

# Internal tech-debt notes — never commit.
tech-debt.md
scripts/one-offs/
.nyc_output/

# Code analysis tools
# Baselines (health-baseline.json, dupes-baseline.json) ARE tracked so CI
# and pre-commit hooks share the same floor; only the incremental cache
# and churn snapshot are regenerable and ignored.
.fallow/cache.bin
.fallow/churn.bin
.brv/
.perf-baselines/

# NPM configuration (contains auth tokens)
.npmrc

# Platform-specific deploy configs (canonical copies live in deploy/)
railway.toml
*.tgz

# Superpowers skill plugin output — agent-generated specs/plans, internal-only.
docs/superpowers/
