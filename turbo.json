{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "turbo.json",
    ".npmrc"
  ],
  "globalEnv": [
    "CI",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.md",
        "!**/__tests__/**",
        "!**/*.test.*",
        "!**/*.spec.*"
      ],
      "outputs": [
        "dist/**",
        "build/**",
        "lib/**",
        ".tsup/**",
        ".tsbuildinfo"
      ],
      "env": ["NODE_ENV"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "tsconfig*.json",
        "!**/*.md"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "vitest.config.*",
        "jest.config.*",
        "playwright.config.*"
      ],
      "outputs": [],
      "env": ["NODE_ENV", "VITEST", "JEST_WORKER_ID"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".eslintrc*",
        "eslint.config.*",
        ".prettierrc*",
        "!**/*.md"
      ],
      "outputs": []
    },
    "code-health": {
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        ".fallowrc.json",
        "../../package.json",
        "../../pnpm-lock.yaml"
      ],
      "outputs": []
    },
    "docs-contract": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../docs/**",
        "../../tests/smoke/docs-contract/**"
      ],
      "outputs": []
    },
    "pack-dry-run": {
      "dependsOn": ["^build", "build"],
      "cache": false
    },
    "public-integration-smoke": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "ATOMICMEMORY_SMOKE_MODE",
        "ATOMICMEMORY_API_BASE_URL"
      ]
    },
    "repo-hygiene": {
      "cache": false
    },
    "security-compliance": {
      "cache": false
    }
  }
}
